      "name": "Create Biometric Integration",
      "method": "POST",
      "endpoint": "/api/biometric?companyId&branchId",
      "description": "Creates a new biometric integration for the selected company and branch. Supported Types are BIOTIME and ZLINK. Note: areaCode is mandatory only for BIOTIME; it should be null for ZLINK.",
