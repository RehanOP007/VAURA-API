
  {
    "module": 2,
    "category": "Admin Management APIs",
    "apis": [
      {
        "id": "create-admin-branch-company",
        "name": "Create Admin (Branch / Company)",
        "method": "POST",
        "endpoint": "/api/admins/create?{username}&{password}&{roles=SUPERADMIN}",
        "description": "Creates a new administrator account for a branch or company. The admin is restricted to the assigned company and branch. Must be executed by SUPERADMIN.",
        "headers": [
          {
            "key": "Authorization",
            "value": "Bearer JWT_TOKEN"
          }
        ],
        "queryParams": [
          {
            "name": "username",
            "type": "string",
            "required": true,
            "description": "Admin username"
          },
          {
            "name": "password",
            "type": "string",
            "required": true,
            "description": "Admin password"
          },
          {
            "name": "roles",
            "type": "enum",
            "required": true,
            "description": "Role (e.g. SUPERADMIN)"
          },
          {
            "name": "companyId",
            "type": "number",
            "required": true,
            "description": "Company ID"
          },
          {
            "name": "branchId",
            "type": "number",
            "required": true,
            "description": "Branch ID"
          }
        ],
        "requestBody": {
  "type": "application/json",
  "fields": [
    {
      "name": "username",
      "type": "String",
      "required": true,
      "description": "Admin username"
    },
    {
      "name": "password",
      "type": "String",
      "required": true,
      "description": "Admin password"
    },
    {
      "name": "roles",
      "type": "String",
      "required": true,
      "description": "Role (BRANCHADMIN)"
    },
    {
      "name": "companyId",
      "type": "Number",
      "required": true,
      "description": "Company ID"
    },
    {
      "name": "branchId",
      "type": "Number",
      "required": true,
      "description": "Branch ID"
    }
  ],
  "sample": {
    "username": "branchadmin01",
    "password": "Admin@123",
    "roles": "BRANCHADMIN",
    "companyId": 1,
    "branchId": 101
  }
},
        "response": null,
        "statusCodes": [
          {
            "code": 200,
            "description": "Ok"
          },
          {
            "code": 401,
            "description": "Invalid credentials"
          },
          {
            "code": 500,
            "description": "Internal server error"
          }
        ]
      },
