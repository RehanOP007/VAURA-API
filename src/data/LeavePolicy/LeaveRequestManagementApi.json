{
  "module": 23,
  "category": "Leave Request Management APIs",
  "apis": [
    {
      "id": "apply-leave-request",
      "name": "Apply Leave Request",
      "method": "POST",
      "endpoint": "/api/leave-requests/apply?{companyId}&{branchId}",
      "description": "Employee applies for FULL / HALF / SHORT leave under an assigned leave policy.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer YOUR_JWT_TOKEN"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company identifier"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch identifier"
        }
      ],
      "requestBody": {
        "type": "application/json",
        "sample": [
          {
            "label": "FULL Leave",
            "sample": {
              "employeeId": 12,
              "leavePolicyId": 2,
              "startDateUtc": "2026-09-17T18:30:00Z",
              "endDateUtc": "2026-09-17T22:40:59Z",
              "leaveType": "FULL",
              "reason": "Family function"
            }
          },
          {
            "label": "HALF Leave",
            "sample": {
              "employeeId": 10,
              "leavePolicyId": 3,
              "startDateUtc": "2026-01-20T00:00:00Z",
              "endDateUtc": "2026-01-20T00:00:00Z",
              "leaveType": "HALF",
              "half": 1,
              "reason": "Doctor visit"
            }
          },
          {
            "label": "SHORT Leave",
            "sample": {
              "employeeId": 10,
              "leavePolicyId": 3,
              "startDateUtc": "2026-01-21T00:00:00Z",
              "endDateUtc": "2026-01-21T00:00:00Z",
              "leaveType": "SHORT",
              "half": 3,
              "reason": "Bank work"
            }
          }
        ]
      },
      "response": null,
      "statusCodes": [
        {
          "code": 200,
          "description": "Ok"
        },
        {
          "code": 401,
          "description": "Invalid credentials"
        },
        {
          "code": 500,
          "description": "Internal server error"
        }
      ]
    },
