{
  "module": 34,
  "category": "Employee Notes APIs",
  "apis": [
    {
      "id": "add-employee-note",
      "name": "Add Note",
      "method": "POST",
      "endpoint": "/api/employee-notes?{companyId}&{branchId}&{employeeId}&{note}&{userId}",
      "description": "Appends a new documentation note record to a chosen employee profile context utilizing structural string query values.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer YOUR_TOKEN"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        },
        {
          "key": "Accept",
          "value": "application/json"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company ID"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch ID"
        },
        {
          "name": "employeeId",
          "type": "number",
          "required": true,
          "description": "Employee ID"
        },
        {
          "name": "note",
          "type": "string",
          "required": true,
          "description": "Note content (URL encoded)"
        },
        {
          "name": "userId",
          "type": "number",
          "required": true,
          "description": "Created user ID"
        }
      ],
      "requestBody": null,
      "response": {
        "type": "application/json",
        "sample": {
          "success": true,
          "message": "Notes fetched successfully",
          "data": [
            {
              "id": 10,
              "note": "Good performance",
              "createdBy": 5,
              "createdAt": "2026-05-01T10:30:00"
            }
          ]
        }
      },
      "statusCodes": [
        {
            "code": 200,
            "description": "Ok"
          },
          {
            "code": 401,
            "description": "Invalid credentials"
          },
          {
            "code": 500,
            "description": "Internal server error"
          }
      ]
    },
