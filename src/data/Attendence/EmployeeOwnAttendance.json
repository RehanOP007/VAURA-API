{
  "module": 21,
  "category": "Employee Self-Service Attendance APIs",
  "apis": [
    {
      "id": "employee-own-attendance-date-only",
      "name": "Employee Own Attendance - Date Only",
      "method": "GET",
      "endpoint": "/api/attendance/own?{companyId}&{branchId}&{date}",
      "description": "Gets logged-in employee’s own attendance for a specific date.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer YOUR_JWT_TOKEN"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company ID"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch ID"
        },
        {
          "name": "date",
          "type": "string (YYYY-MM-DD)",
          "required": true,
          "description": "Attendance date"
        }
      ],
      "requestBody": null,
      "response": null,
      "statusCodes": []
    },
