{
  "module": 29,
  "category": "Admin Meeting & Interview APIs",
  "apis": [
    {
      "id": "create-meeting-interview",
      "name": "Create Meeting (Interview) + Optional Document",
      "method": "POST",
      "endpoint": "/api/meetings?{companyId}&{branchId}",
      "description": "Creates an interview meeting and optionally uploads an interview sheet/document.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer ADMIN_TOKEN"
        },
        {
          "key": "Content-Type",
          "value": "multipart/form-data"
        },
        {
          "key": "Accept",
          "value": "application/json"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company identifier"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch identifier"
        }
      ],
      "requestBody": {
        "type": "multipart/form-data",
        "fields": [
          {
            "name": "meeting",
            "type": "application/json",
            "required": true,
            "description": "Meeting details object"
          },
          {
            "name": "doc",
            "type": "file (pdf/doc/docx)",
            "required": false,
            "description": "Optional interview sheet or evaluation rubric file"
          }
        ],
        "sample": {
          "meeting": {
            "title": "Interview Round 1",
            "type": "INTERVIEW",
            "mode": "ONLINE",
            "meetingLink": "https://meet.google.com/xxx-yyy-zzz",
            "agenda": "Java + Spring discussion",
            "startAtUtc": "2026-02-20T10:00:00",
            "endAtUtc": "2026-02-20T10:30:00",
            "candidateId": 5,
            "jobOpeningId": 10,
            "createdByAdminId": 99
          }
        }
      },
      "response": null,
      "statusCodes": [
        {
            "code": 200,
            "description": "Ok"
          },
          {
            "code": 401,
            "description": "Invalid credentials"
          },
          {
            "code": 500,
            "description": "Internal server error"
          }
      ]
    },
    {
      "id": "update-meeting-details",
      "name": "Update Meeting Time / Details (Triggers Conflict Re-check)",
      "method": "PUT",
      "endpoint": "/api/meetings/{meetingId}?{companyId}&{branchId}",
      "description": "Updates meeting time/details and triggers an automated scheduler conflict re-check before saving.",
