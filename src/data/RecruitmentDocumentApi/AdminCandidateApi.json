{
  "module": 28,
  "category": "Admin Candidate & Evaluation Notes APIs",
  "apis": [
    {
      "id": "list-candidates-scoped",
      "name": "List Candidates (Scoped + Filter by Job)",
      "method": "GET",
      "endpoint": "/api/candidates?{companyId}&{branchId}&{jobOpeningId}",
      "description": "Returns candidates list only within tenant scope and optionally filtered by jobOpeningId.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer ADMIN_TOKEN"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company identifier"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch identifier"
        },
        {
          "name": "jobOpeningId",
          "type": "number",
          "required": false,
          "description": "Filter candidates by job opening"
        }
      ],
      "requestBody": null,
      "response": null,
      "statusCodes": []
    },
    {
      "id": "update-candidate-status",
      "name": "Update Candidate Status",
      "method": "PATCH",
      "endpoint": "/api/candidates/{candidateId}/status?{companyId}&{branchId}&{status=SHORTLISTED}",
      "description": "Updates candidate status (e.g., SHORTLISTED, INTERVIEW, REJECTED etc.) using a partial workflow update.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer ADMIN_TOKEN"
        }
      ],
      "pathVariables": [
        {
          "name": "candidateId",
          "type": "number",
          "required": true,
          "description": "Candidate ID"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company identifier"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch identifier"
        },
        {
          "name": "status",
          "type": "string",
          "required": true,
          "description": "New candidate status configuration"
        }
      ],
      "requestBody": null,
      "response": null,
      "statusCodes": []
    },
    {
      "id": "add-internal-candidate-note",
      "name": "Add INTERNAL Note (Candidate Cannot See)",
      "method": "POST",
      "endpoint": "/api/candidate-notes?{companyId}&{branchId}",
      "description": "Adds an INTERNAL evaluation note containing administrative review details. This note is never visible to the candidate workflow profile.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer ADMIN_TOKEN"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company identifier"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch identifier"
        }
      ],
      "requestBody": {
        "type": "application/json",
        "sample": {
          "candidateId": 5,
          "jobOpeningId": 10,
          "stage": "INTERVIEW_ROUND_1",
          "noteType": "INTERNAL",
          "note": "Good communication but weak system design",
          "score": 6,
          "decision": "NEXT_ROUND",
          "createdByAdminId": 99
        }
      },
      "response": null,
      "statusCodes": []
    },
