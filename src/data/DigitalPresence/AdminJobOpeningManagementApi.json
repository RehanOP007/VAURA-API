    {
      "id": "update-job-opening-with-image",
      "name": "Update Job Opening (With Image)",
      "method": "PUT",
      "endpoint": "/api/job-openings/{id}?{companyId}&{branchId}",
      "description": "Admin updates job details and replaces/updates the job poster image.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer YOUR_ADMIN_TOKEN"
        },
        {
          "key": "Content-Type",
          "value": "multipart/form-data"
        },
        {
          "key": "Accept",
          "value": "application/json"
        }
      ],
      "pathVariables": [
        {
          "name": "id",
          "type": "number",
          "required": true,
          "description": "Job opening ID"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company identifier"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch identifier"
        }
      ],
      "requestBody": {
        "type": "multipart/form-data",
        "fields": [
          {
            "name": "job",
            "type": "application/json",
            "required": true,
            "description": "Updated job fields"
          },
          {
            "name": "file",
            "type": "file (image)",
            "required": true,
            "description": "New job poster or banner image"
          }
        ],
        "sample": {
          "job": {
            "jobTopic": "Backend Updated",
            "experience": ["5+ years Java", "AWS"],
            "responsibility": ["Lead Team"],
            "qualification": ["BSc SE"],
            "benifite": ["Bonus"],
            "status": "PUBLISHED"
          }
        }
      },
      "response": null,
      "statusCodes": []
    },
