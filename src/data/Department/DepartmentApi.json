
  {
    "module": 6,
    "category": "Department APIs",
    "apis": [
      {
        "id": "add-department",
        "name": "Add Department",
        "method": "POST",
        "endpoint": "/api/departments?{companyId}&{branchId}",
        "description": "Creates a new department under a company/branch.",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer JWT_TOKEN"
          }
        ],
        "queryParams": [
          {
            "name": "companyId",
            "type": "number",
            "required": true,
            "description": "Company ID"
          },
          {
            "name": "branchId",
            "type": "number",
            "required": true,
            "description": "Branch ID"
          }
        ],
        "requestBody": {
          "type": "application/json",
          "sample": {
            "departmentName": "IT Department"
          }
        },
        "response": null,
        "statusCodes": []
      },
      {
        "id": "get-departments-in-branch",
        "name": "Get Department In Branch",
        "method": "GET",
        "endpoint": "/api/departments/by-company-branch?{companyId}&{branchId}",
        "description": "Fetches all departments for a specific company and branch.",
        "headers": [
          {
            "key": "Authorization",
            "value": "Bearer JWT_TOKEN"
          }
        ],
        "queryParams": [
          {
            "name": "companyId",
            "type": "number",
            "required": true,
            "description": "Company ID"
          },
          {
            "name": "branchId",
            "type": "number",
            "required": true,
            "description": "Branch ID"
          }
        ],
        "requestBody": null,
        "response": null,
        "statusCodes": []
      },
      {
        "id": "update-department",
        "name": "Update Department In Branch",
        "method": "PUT",
        "endpoint": "/api/departments/{departmentId}",
        "description": "Updates department details including optional manager assignment.",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer JWT_TOKEN"
          }
        ],
        "pathVariables": [
          {
            "name": "departmentId",
            "type": "number",
            "required": true,
            "description": "Department ID"
          }
        ],
        "queryParams": [],
        "requestBody": {
          "type": "application/json",
          "sample": {
            "departmentName": "Updated IT Dept",
            "manager": {
              "employeeId": 6
            }
          }
        },
        "response": null,
        "statusCodes": []
      },
      {
        "id": "delete-department",
        "name": "Delete Department",
        "method": "DELETE",
        "endpoint": "/api/departments/{departmentId}",
        "description": "Deletes a department by ID.",
        "headers": [
          {
            "key": "Authorization",
            "value": "Bearer JWT_TOKEN"
          }
        ],
        "pathVariables": [
          {
            "name": "departmentId",
            "type": "number",
            "required": true,
            "description": "Department ID"
          }
        ],
        "queryParams": [],
        "requestBody": null,
        "response": null,
        "statusCodes": []
      }
    ]
  }
