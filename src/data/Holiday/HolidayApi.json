
 {
    "module": 11,
    "category": "Holiday APIs",
    "apis": [
      {
        "id": "add-holiday",
        "name": "Add Holiday",
        "method": "POST",
        "endpoint": "/api/holidays?{companyId}&{branchId}",
        "description": "Creates a single holiday for a branch.",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer JWT_TOKEN"
          }
        ],
        "queryParams": [
          {
            "name": "companyId",
            "type": "number",
            "required": true,
            "description": "Company ID"
          },
          {
            "name": "branchId",
            "type": "number",
            "required": true,
            "description": "Branch ID"
          }
        ],
        "requestBody": {
          "type": "application/json",
          "sample": {
            "holidayDate": "2026-01-01",
            "name": "New Year Day",
            "isRecurring": true,
            "description": "Public holiday"
          }
        },
        "response": null,
        "statusCodes": []
      },
