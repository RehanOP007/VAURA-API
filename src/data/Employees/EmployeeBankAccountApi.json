{
    "module": 13,
    "category": "Employee Bank Account APIs",
    "apis": [
      {
        "id": "create-employee-bank-account",
        "name": "Create Employee Bank Account",
        "method": "POST",
        "endpoint": "/api/admin/employees/{employeeId}/bank-account",
        "description": "Creates a bank account record for an employee with optional document upload.",
        "headers": [
          {
            "key": "Authorization",
            "value": "Bearer JWT_TOKEN"
          }
        ],
        "pathVariables": [
          {
            "name": "employeeId",
            "type": "number",
            "required": true,
            "description": "Employee ID"
          }
        ],
        "queryParams": [
          {
            "name": "companyId",
            "type": "number",
            "required": true,
            "description": "Company ID"
          },
          {
            "name": "branchId",
            "type": "number",
            "required": true,
            "description": "Branch ID"
          }
        ],
        "requestBody": {
          "type": "multipart/form-data",
          "fields": [
            {
              "name": "data",
              "type": "JSON String",
              "required": true,
              "description": "Bank account details as JSON"
            },
            {
              "name": "file",
              "type": "File",
              "required": false,
              "description": "Bank document attachment (e.g. PDF or image)"
            }
          ],
          "sample": {
            "data": {
              "bankId": 3,
              "bankBranchName": "Malabe",
              "bankBranchCode": "MLB001",
              "accountNumber": "1234567890",
              "accountHolderName": "Kasun Perera",
              "bankDocumentAttachment": null
            },
            "file": "<file>"
          }
        },
        "response": {
          "sample": "Employee bank account created successfully"
        },
        "statusCodes": []
      },
      {
