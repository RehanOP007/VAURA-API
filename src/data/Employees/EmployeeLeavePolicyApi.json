{
  "module": 15,
  "category": "Employee Leave Policy Management APIs",
  "apis": [
    {
      "id": "assign-leave-policy-to-employee",
      "name": "Assign Leave Policy to Employee",
      "method": "POST",
      "endpoint": "/api/employee-leave-policies/assign?{companyId}&{branchId}",
      "description": "Assigns a leave policy to an employee with an opening balance and effective period.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer JWT_TOKEN"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company ID"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch ID"
        }
      ],
      "requestBody": {
        "type": "application/json",
        "sample": {
          "employeeId": 12,
          "leavePolicyId": 1,
          "effectiveFrom": "2026-01-02",
          "expireDate": null,
          "priority": 1,
          "openingBalance": 14
        }
      },
      "response": null,
      "statusCodes": []
    },
    {
      "id": "update-employee-leave-balance",
      "name": "Update Employee Leave Balance",
      "method": "PUT",
      "endpoint": "/api/employee-leave-policies/balance?{companyId}&{branchId}",
      "description": "Updates the leave balance of an employee for a specific year and leave policy.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer JWT_TOKEN"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company ID"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch ID"
        }
      ],
      "requestBody": {
        "type": "application/json",
        "sample": {
          "employeeId": 12,
          "leavePolicyId": 2,
          "year": 2025,
          "openingBalance": 12,
          "used": 3,
          "remaining": 11
        }
      },
      "response": null,
      "statusCodes": []
    },
    {
