          {
            "key": "Authorization",
            "value": "Bearer JWT_TOKEN"
          }
        ],
        "pathVariables": [
          {
            "name": "adminId",
            "type": "number",
            "required": true,
            "description": "Admin ID"
          }
        ],
        "queryParams": [
          {
            "name": "adminId",
            "type": "number",
            "required": true,
            "description": "Admin ID"
          }
        ],
        "requestBody": null,
        "response": [
          {
