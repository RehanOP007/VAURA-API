  
  {
    "module": 9,
    "category": "Asset APIs",
    "apis": [
      {
        "id": "add-asset",
        "name": "Add Asset",
        "method": "POST",
        "endpoint": "/api/assets?{companyId}&{branchId}",
        "description": "Creates a new asset record for a branch.",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer JWT_TOKEN"
          }
        ],
        "queryParams": [
          {
            "name": "companyId",
            "type": "number",
            "required": true,
            "description": "Company ID"
          },
          {
            "name": "branchId",
            "type": "number",
            "required": true,
            "description": "Branch ID"
          }
        ],
        "requestBody": {
          "type": "application/json",
          "sample": {
            "assetCode": "LAP-001",
            "assetName": "Dell Latitude 5420",
            "category": "LAPTOP",
            "brand": "DELL",
            "model": "5420",
            "serialNumber": "SN-12345",
            "conditionStatus": "GOOD",
            "description": "Office laptop",
            "active": true
          }
        },
        "response": null,
        "statusCodes": []
      },
      {
