      {
        "id": "add-designation",
        "name": "Add Designation",
        "method": "POST",
        "endpoint": "/api/designations?{companyId}&{branchId}",
        "description": "Creates a new designation for a branch.",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer JWT_TOKEN"
          }
        ],
        "queryParams": [
          {
            "name": "companyId",
            "type": "number",
            "required": true,
            "description": "Company ID"
          },
          {
            "name": "branchId",
            "type": "number",
            "required": true,
            "description": "Branch ID"
          }
        ],
        "requestBody": {
          "type": "application/json",
          "sample": {
            "designationName": "Software Engineer",
            "hierarchyLevel": "4"
          }
        },
        "response": null,
        "statusCodes": []
      },
