{
  "module": 39,
  "category": "Onboarding Excel Validation APIs",
  "apis": [
    {
      "id": "import-onboarding-data-excel-dry-run-v2",
      "name": "Import Onboarding Data from Excel (Dry Run)",
      "method": "POST",
      "endpoint": "/api/onboarding-import/excel?{companyId}&{branchId}&{dryRun=true}",
      "description": "Validates all sheets and records within the uploaded onboarding Excel template without saving data to the persistent database. Returns extensive validation results, a high-level import summary, and contextual error logs.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer your_jwt_token"
        },
        {
          "key": "Content-Type",
          "value": "multipart/form-data"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company identification code"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch identification code"
        },
        {
          "name": "dryRun",
          "type": "boolean",
          "required": true,
          "description": "Flag to enforce transactional sandbox validation without persistence"
        }
      ],
      "requestBody": {
        "type": "multipart/form-data",
        "fields": [
          {
            "name": "file",
            "type": "file (.xlsx)",
            "required": true,
            "description": "Onboarding master data template workbook file binary payload"
          }
        ],
        "sample": null
      },
      "response":null,
      "statusCodes": []
    }
  ]
}