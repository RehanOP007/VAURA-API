{
  "module": 16,
  "category": "Employee Shift Management APIs",
  "apis": [
    {
      "id": "assign-shift-to-employee",
      "name": "Assign Shift to Employee",
      "method": "POST",
      "endpoint": "/api/admin/employee-shifts/assign?{companyId}&{branchId}",
      "description": "Assigns a working shift to an employee starting from the specified date and time.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer JWT_TOKEN"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company ID"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch ID"
        }
      ],
      "requestBody": {
        "type": "application/json",
        "sample": {
          "employeeId": 12,
          "shiftId": 3,
          "startDateTime": "2026-01-30T09:00:00"
        }
      },
      "response": null,
      "statusCodes": [
        {
            "code": 200,
            "description": "Ok"
          },
          {
            "code": 401,
            "description": "Invalid credentials"
          },
          {
            "code": 500,
            "description": "Internal server error"
          }
      ]
    },
    {
      "id": "get-active-shift-of-employee",
      "name": "Get Active Shift of an Employee",
      "method": "GET",
      "endpoint": "/api/admin/employee-shifts/employee/{employeeId}?{companyId}&{branchId}",
      "description": "Retrieves the currently active shift assigned to a specific employee.",
