            "name": "companyId",
            "type": "number",
            "required": true,
            "description": "Company ID"
          },
          {
            "name": "branchId",
            "type": "number",
            "required": true,
            "description": "Branch ID"
          }
        ],
        "requestBody": {
          "type": "application/json",
          "sample": {
