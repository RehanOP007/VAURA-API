    {
      "id": "edit-attendance-record",
      "name": "Edit Attendance Record (Admin Manual Correction)",
      "method": "PUT",
      "endpoint": "/api/attendance/edit?{companyId}&{branchId}",
      "description": "Allows admin-level manual correction of attendance records: Change status (PRESENT / ABSENT / LEAVE), Modify IN / OUT times, Adjust work, late & overtime minutes, and manually change assigned shift.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer YOUR_JWT_TOKEN"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company identifier"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch identifier"
        }
      ],
      "requestBody": {
        "type": "application/json",
        "fields": [
          {
            "name": "attendanceId",
            "type": "number",
            "required": true,
            "description": "Attendance record unique identifier"
          },
          {
            "name": "status",
            "type": "string",
            "required": false,
            "description": "Attendance status (PRESENT / ABSENT / LEAVE)"
          },
          {
            "name": "location",
            "type": "string",
            "required": false,
            "description": "Work location flag"
          },
          {
            "name": "shiftId",
            "type": "number",
            "required": false,
            "description": "ID of assigned schedule shift"
          },
          {
            "name": "firstInTime",
            "type": "string (HH:mm)",
            "required": false,
            "description": "First clock in timestamp"
          },
          {
            "name": "lastOutTime",
            "type": "string (HH:mm)",
            "required": false,
            "description": "Last clock out timestamp"
          },
          {
            "name": "workedMinutes",
            "type": "number",
            "required": false,
            "description": "Total duration worked inside shift in minutes"
          },
          {
            "name": "lateMinutes",
            "type": "number",
            "required": false,
            "description": "Late arrival variance in minutes"
          },
          {
            "name": "overtimeMinutes",
            "type": "number",
            "required": false,
            "description": "Overtime logging in minutes"
          }
        ],
        "sample": {
          "attendanceId": 55,
          "status": "PRESENT",
          "location": "OFFICE",
          "shiftId": 4,
          "firstInTime": "09:02",
          "lastOutTime": "18:01",
          "workedMinutes": 535,
          "lateMinutes": 2,
          "overtimeMinutes": 15
        }
      },
      "response": null,
      "statusCodes": []
    }
