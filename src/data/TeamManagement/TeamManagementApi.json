      "id": "create-parent-team",
      "name": "Create Parent Team",
      "method": "POST",
      "endpoint": "/api/teams?companyId&branchId",
      "description": "Creates a main parent team under a department.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer YOUR_TOKEN"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company ID"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch ID"
        }
      ],
      "requestBody": {
        "type": "application/json",
        "sample": {
          "departmentId": 1,
          "teamName": "Factory Team"
        }
      },
      "response": null,
      "statusCodes": []
    },
