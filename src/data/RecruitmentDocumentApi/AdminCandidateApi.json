      "endpoint": "/api/candidates/{candidateId}/status?{companyId}&{branchId}&{status=SHORTLISTED}",
      "description": "Updates candidate status (e.g., SHORTLISTED, INTERVIEW, REJECTED etc.) using a partial workflow update.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer ADMIN_TOKEN"
        }
      ],
      "pathVariables": [
        {
          "name": "candidateId",
          "type": "number",
          "required": true,
          "description": "Candidate ID"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company identifier"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch identifier"
        },
        {
          "name": "status",
          "type": "string",
          "required": true,
          "description": "New candidate status configuration"
        }
      ],
      "requestBody": null,
      "response": null,
      "statusCodes": []
