      {
        "id": "add-shift",
        "name": "Add Shift",
        "method": "POST",
        "endpoint": "/api/work-shifts?{companyId}&{branchId}",
        "description": "Creates a new work shift for a branch.",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer JWT_TOKEN"
          }
        ],
        "queryParams": [
          {
            "name": "companyId",
            "type": "number",
            "required": true,
            "description": "Company ID"
          },
          {
            "name": "branchId",
            "type": "number",
            "required": true,
            "description": "Branch ID"
          }
        ],
        "requestBody": {
          "type": "application/json",
          "sample": {
            "name": "Morning Shift",
            "startTime": "09:00",
            "endTime": "18:00",
            "isOvernight": false,
            "graceMinutes": 15,
            "halfDayMinutes": 240,
            "fullDayMinutes": 480
          }
        },
        "response": null,
        "statusCodes": []
      },
