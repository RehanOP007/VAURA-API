      {
        "id": "create-employee-admin",
        "name": "Create Admin (Employee)",
        "method": "POST",
        "endpoint": "/api/admins/create?{username}&{password}&roles=EMPLOYEE&{employeeId}&{companyId}&{branchId}",
        "description": "Creates login credentials for an employee.",
        "headers": [
          {
            "key": "Authorization",
            "value": "Bearer JWT_TOKEN"
          }
        ],
        "queryParams": [
          {
            "name": "username",
            "type": "string",
            "required": true,
            "description": "Login username for employee"
          },
          {
            "name": "password",
            "type": "string",
            "required": true,
            "description": "Login password"
          },
          {
            "name": "roles",
            "type": "enum",
            "required": true,
            "description": "Role must be EMPLOYEE"
          },
          {
            "name": "employeeId",
            "type": "number",
            "required": true,
            "description": "Linked employee ID"
          },
          {
            "name": "companyId",
            "type": "number",
            "required": true,
            "description": "Company ID"
          },
          {
            "name": "branchId",
            "type": "number",
            "required": true,
            "description": "Branch ID"
          }
        ],
        "requestBody": {
  "type": "application/json",
  "fields": [
    {
      "name": "username",
      "type": "String",
      "required": true,
      "description": "Login username for employee"
    },
    {
      "name": "password",
      "type": "String",
      "required": true,
      "description": "Login password"
    },
    {
      "name": "roles",
      "type": "String",
      "required": true,
      "description": "Role must be EMPLOYEE"
    },
    {
      "name": "employeeId",
      "type": "Number",
      "required": true,
      "description": "Link employee ID"
    },
    {
      "name": "companyId",
      "type": "Number",
      "required": true,
      "description": "Company ID"
    },
    {
      "name": "branchId",
      "type": "Number",
      "required": true,
      "description": "Branch ID"
    }
  ],
