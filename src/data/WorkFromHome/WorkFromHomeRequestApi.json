{
  "module": 18,
  "category": "WFH Request Management APIs",
  "apis": [
    {
      "id": "apply-wfh-request",
      "name": "Apply WFH Request",
      "method": "POST",
      "endpoint": "/api/wfh-request/apply?{companyId}&{branchId}&{employeeId}",
      "description": "Creates a work-from-home request for an employee. If the requester is a manager, the request becomes manager-approved automatically.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer ADMIN_TOKEN / EMPLOYEE_TOKEN"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        },
        {
          "key": "Accept",
          "value": "application/json",
          "required": false
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company ID"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch ID"
        },
        {
          "name": "employeeId",
          "type": "number",
          "required": true,
          "description": "Employee ID"
        }
      ],
      "requestBody": {
        "type": "application/json",
        "sample": {
          "startDate": "2026-03-20",
          "endDate": "2026-03-22",
          "reason": "Need to work from home due to personal reason"
        }
      },
      "response": null,
      "statusCodes": []
    },
    {
      "id": "manager-approve-wfh-request",
      "name": "Manager Approve WFH Request",
      "method": "PUT",
      "endpoint": "/api/wfh-request/manager-approve/{requestId}?{companyId}&{branchId}",
      "description": "Manager approves a pending WFH request.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer MANAGER_TOKEN"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        },
        {
          "key": "Accept",
          "value": "application/json",
          "required": false
        }
      ],
      "pathVariables": [
        {
          "name": "requestId",
          "type": "number",
          "required": true,
          "description": "WFH Request ID"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company ID"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch ID"
        }
      ],
      "requestBody": {
        "type": "application/json",
        "sample": {
          "notes": "Approved by manager"
        }
      },
      "response": null,
      "statusCodes": []
    },
    {
      "id": "final-admin-approve-wfh-request",
      "name": "Final Admin Approve WFH Request",
      "method": "PUT",
      "endpoint": "/api/wfh-request/final-approve/{requestId}?{companyId}&{branchId}",
      "description": "Admin gives final approval to a WFH request. After this, the actual Work From Home record is created.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer ADMIN_TOKEN"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        },
        {
          "key": "Accept",
          "value": "application/json",
          "required": false
        }
      ],
      "pathVariables": [
        {
          "name": "requestId",
          "type": "number",
          "required": true,
          "description": "WFH Request ID"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company ID"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch ID"
        }
      ],
      "requestBody": {
        "type": "application/json",
        "sample": {
          "notes": "Final approval completed by HR admin"
        }
      },
      "response": null,
      "statusCodes": []
    },
    {
