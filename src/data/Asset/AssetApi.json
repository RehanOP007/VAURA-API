          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer JWT_TOKEN"
          }
        ],
        "pathVariables": [
          {
            "name": "assetId",
            "type": "number",
            "required": true,
