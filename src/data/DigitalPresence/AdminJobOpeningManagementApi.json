{
  "module": 25,
  "category": "Admin Job Opening Management APIs",
  "apis": [
    {
      "id": "create-job-opening-with-image",
      "name": "Create Job Opening (With Image)",
      "method": "POST",
      "endpoint": "/api/job-openings?{companyId}&{branchId}",
      "description": "Admin creates a job opening under a specific company + branch with an uploaded poster/image.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer YOUR_ADMIN_TOKEN"
        },
        {
          "key": "Content-Type",
          "value": "multipart/form-data"
        },
        {
          "key": "Accept",
          "value": "application/json"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company identifier"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch identifier"
        }
      ],
      "requestBody": {
        "type": "multipart/form-data",
        "fields": [
          {
            "name": "job",
            "type": "application/json",
            "required": true,
            "description": "Job description configurations and details"
          },
          {
            "name": "file",
            "type": "file (image)",
            "required": true,
            "description": "Job poster or banner image"
          }
        ],
        "sample": {
          "job": {
            "jobTopic": "Senior Backend Engineer",
            "description": "Hiring Backend Developer",
            "experience": ["3+ years Java", "Spring Boot"],
            "responsibility": ["Develop APIs", "Code reviews"],
            "qualification": ["BSc SE"],
            "benifite": ["Remote Work", "Insurance"],
            "closingDate": "2026-03-30",
            "status": "OPEN",
            "level": "URGENT",
            "linkedin": "YES",
            "topJob": "NO",
            "link": "https://company.com/jobs/123"
          }
        }
      },
      "response": null,
      "statusCodes": []
    },
