      {
        "id": "create-company-profile",
        "name": "Create Company Profile",
        "method": "POST",
        "endpoint": "/api/company-profiles",
        "description": "Creates a company profile with image upload.",
        "headers": [
          {
            "key": "Authorization",
            "value": "Bearer JWT_TOKEN"
          },
          {
            "key": "Content-Type",
            "value": "multipart/form-data"
          }
        ],
        "queryParams": [
            {
    "name": "name",
    "type": "string",
    "required": true,
    "description": "Company name"
  },
  {
    "name": "phoneNumber",
    "type": "string",
    "required": true,
    "description": "Company contact phone number"
  },
  {
    "name": "email",
    "type": "string",
    "required": true,
    "description": "Company email address"
  },
  {
    "name": "remark",
    "type": "string",
    "required": false,
    "description": "Additional remarks or notes about the company"
  },
  {
    "name": "logoLink",
    "type": "string",
    "required": false,
    "description": "URL or path to the company logo"
  },
  {
    "name": "location",
    "type": "string",
    "required": true,
    "description": "Company location or city"
  },
  {
    "name": "address",
    "type": "string",
    "required": true,
    "description": "Company address"
  },
  {
    "name": "prefix",
    "type": "string",
    "required": true,
    "description": "Company prefix used for codes or identifiers"
  },
  {
    "name": "companyCode",
    "type": "string",
    "required": true,
    "description": "Unique company code"
  }
        ],
        "requestBody": {
          "type": "multipart/form-data",
          "fields": [
            {
              "name": "company",
              "type": "JSON String",
              "required": true,
              "description": "Company information as JSON"
            },
            {
              "name": "photo",
              "type": "File",
              "required": true,
              "description": "Company image"
            }
          ],
          "sample": {
            "company": {
              "name": "VentureCorp",
              "phoneNumber": "0771234567",
              "email": "info@venturecorp.com",
              "remark": "Main company",
              "logoLink": "",
              "location": "Colombo",
              "address": "No 10, Colombo",
              "prefix": "VC",
              "companyCode": "VC001"
            },
            "photo": "<file>"
          }
        },
        "response": null,
        "statusCodes": [
          {
            "code": 200,
            "description": "Ok"
          },
          {
            "code": 401,
            "description": "Invalid credentials"
          },
          {
            "code": 500,
            "description": "Internal server error"
          }
        ]
      },
