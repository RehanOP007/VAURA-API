{
  "module": 20,
  "category": "QR Code Attendance Management APIs",
  "apis": [
    {
      "id": "qr-code-mark-attendance",
      "name": "QR Code (Mark Attendance)",
      "method": "POST",
      "endpoint": "/api/attendance/qr/scan?companyId&{branchId}",
      "description": "Used by employee to scan QR code. Marks IN / OUT attendance automatically. Validates QR token, employee, branch & company, and prevents duplicate scans.",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company ID"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch ID"
        }
      ],
      "requestBody": {
        "type": "application/json",
        "fields": [
          {
            "name": "employeeId",
            "type": "number",
            "required": true,
            "description": "Unique identifier of the employee scanning the QR code"
          },
          {
            "name": "token",
            "type": "string",
            "required": true,
            "description": "Secure QR token generated by the attendance system"
          }
        ],
        "sample": {
          "employeeId": 11,
          "token": "--7JLpK-3LN2KLjT"
        }
      },
      "response": null,
      "statusCodes": [
        {
            "code": 200,
            "description": "Ok"
          },
          {
            "code": 401,
            "description": "Invalid credentials"
          },
          {
            "code": 500,
            "description": "Internal server error"
          }
      ]
    },
    {
      "id": "generate-qr-token-admin",
      "name": "Generate QR Token (Admin Only)",
      "method": "GET",
      "endpoint": "/api/admin/qr/token?{companyId}&{branchId}",
      "description": "Generates a secure QR code token for a specific branch and company. Accessible by administrators only.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer JWT_TOKEN"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company ID"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch ID"
        }
      ],
      "requestBody": null,
      "response": [
        {
    "companyId": 1,
    "branchId": 1,
    "epochSec": 1782233022,
    "token": "6dfvK1H0wkfamAFb",
    "validForSeconds": 60
}
      ],
      "statusCodes": [
        {
            "code": 200,
            "description": "Ok"
          },
          {
            "code": 401,
            "description": "Invalid credentials"
          },
          {
            "code": 500,
            "description": "Internal server error"
          }
      ]
    }
  ]
}