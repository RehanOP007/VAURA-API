[
  {
    "category": "Authentication API",
    "apis": [
      {
        "id": "login",
        "name": "User Login",
        "method": "POST",
        "endpoint": "http://3.148.245.51:8080/api/auth/login",
        "description": "Authenticates a user and returns an access token",
        "headers": [],
        "queryParams": [],
        "body": {
          "email": "user@example.com",
          "password": "password123"
        },
        "response": {
          "success": true,
          "token": "jwt_token_here",
          "user": {
            "id": 1,
            "name": "John Doe"
          }
        },
        "statusCodes": [
          { "code": 200, "desc": "Login successful" },
          { "code": 401, "desc": "Invalid credentials" },
          { "code": 500, "desc": "Internal server error" }
        ]
      },
      {
        "id": "change-own-password",
        "name": "Change Own Password",
        "method": "PUT",
        "endpoint": "http://localhost:8080/api/admins/me/password",
        "description": "Allows logged-in admin to change own password after validating current password",
        "headers": [
          { "key": "Authorization", "value": "Bearer JWT_TOKEN" }
        ],
        "queryParams": [
          { "name": "currentPassword","type":"string", "required": true ,"description": "Existing Password" },
          { "name": "newPassword","type":"string", "required": true, "description": "New Password" }
        ]
      }
    ]
  },
