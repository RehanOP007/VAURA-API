
  {
    "module": 6,
    "category": "Department APIs",
    "apis": [
      {
        "id": "add-department",
        "name": "Add Department",
        "method": "POST",
        "endpoint": "/api/departments?{companyId}&{branchId}",
        "description": "Creates a new department under a company/branch.",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer JWT_TOKEN"
          }
        ],
        "queryParams": [
          {
            "name": "companyId",
            "type": "number",
            "required": true,
            "description": "Company ID"
          },
          {
            "name": "branchId",
            "type": "number",
            "required": true,
            "description": "Branch ID"
          }
        ],
        "requestBody": {
          "type": "application/json",
          "sample": {
            "departmentName": "IT Department"
          }
        },
        "response": null,
        "statusCodes": [
          {
            "code": 200,
            "description": "Ok"
          },
          {
            "code": 401,
            "description": "Invalid credentials"
          },
          {
            "code": 500,
            "description": "Internal server error"
          }
        ]
      },
