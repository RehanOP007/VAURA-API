    {
      "id": "assign-extend-wfh",
      "name": "Assign / Extend WFH (Auto-merge Overlaps)",
      "method": "POST",
      "endpoint": "/api/admin/wfh/assign?{CompanyId}&{BranchId}",
      "description": "Assigns or extends a Work From Home period for an employee. Overlapping or adjacent WFH periods are automatically merged.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer JWT_TOKEN"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company ID"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch ID"
        }
      ],
      "requestBody": {
        "type": "application/json",
        "sample": [
          {
            "label": "Temporary WFH",
            "sample": {
              "employeeId": 12,
              "startDate": "2026-02-01",
              "endDate": "2026-02-10"
            }
          },
          {
            "label": "Permanent WFH",
            "sample": {
              "employeeId": 12,
              "startDate": "2026-02-01",
              "endDate": null
            }
          }
        ]
      },
      "response": null,
      "statusCodes": []
    },
