      "name": "Delete Note",
      "method": "DELETE",
      "endpoint": "/api/employee-notes/{id}?{companyId}&{branchId}",
      "description": "Removes a specific isolated documentation note item record out of data management systems by using its distinct primary key target variable identifier.",
