    {
      "id": "get-biometric-by-company-and-branch",
      "name": "Get Biometric Integration by Company and Branch",
      "method": "GET",
      "endpoint": "/api/biometric/company/{companyId}/branch/{branchId}",
      "description": "Returns the biometric integration explicitly configured for the designated company and branch combination paths.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer ADMIN_TOKEN"
        }
      ],
      "pathVariables": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Target configuration company ID"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Target configuration branch ID"
        }
      ],
      "queryParams": [],
      "requestBody": null,
      "response": null,
      "statusCodes": []
    },
    {
      "id": "update-biometric-integration",
      "name": "Update Biometric Integration",
      "method": "PUT",
      "endpoint": "/api/biometric/{id}",
      "description": "Updates an existing biometric integration scheme mapping by integration ID parameters.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer ADMIN_TOKEN"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "pathVariables": [
        {
          "name": "id",
          "type": "number",
          "required": true,
          "description": "Biometric integration system record ID"
        }
      ],
      "queryParams": [],
      "requestBody": {
        "type": "application/json",
