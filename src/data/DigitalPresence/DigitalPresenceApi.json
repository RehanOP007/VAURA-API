    {
      "id": "create-digital-presence",
      "name": "Create Digital Presence",
      "method": "POST",
      "endpoint": "/api/digital-presence?{companyId}&{branchId}",
      "description": "Creates a digital presence record (LinkedIn, GitHub, Portfolio, etc.) for an employee under the given tenant scope.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer YOUR_JWT_TOKEN"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company identifier"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch identifier"
        }
      ],
      "requestBody": {
        "type": "application/json",
        "sample": {
          "employeeId": 5,
          "presence": "LinkedIn",
          "url": "https://linkedin.com/in/john-doe"
        }
      },
      "response": null,
      "statusCodes": []
    },
