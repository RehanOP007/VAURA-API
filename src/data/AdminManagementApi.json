        "method": "POST",
        "endpoint": "http://localhost:8080/api/admins/create",
        "description": "Creates a new administrator account for a branch or company. The admin is restricted to the assigned company and branch. Must be executed by SUPERADMIN.",
        "headers": [
          {
            "key": "Authorization",
            "value": "Bearer JWT_TOKEN"
          }
        ],
        "queryParams": [
          {
            "name": "username",
            "type": "string",
            "required": true,
            "description": "Admin username"
          },
          {
            "name": "password",
            "type": "string",
            "required": true,
            "description": "Admin password"
          },
          {
            "name": "roles",
            "type": "enum",
            "required": true,
            "description": "Role (e.g. SUPERADMIN)"
          },
          {
            "name": "companyId",
            "type": "number",
            "required": true,
            "description": "Company ID"
          },
          {
            "name": "branchId",
            "type": "number",
            "required": true,
            "description": "Branch ID"
          }
        ],
        "requestBody": null,
        "response": null,
        "statusCodes": []
      },
