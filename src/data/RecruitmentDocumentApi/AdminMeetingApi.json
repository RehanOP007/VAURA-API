        {
          "key": "Authorization",
          "value": "Bearer ADMIN_TOKEN"
        },
        {
          "key": "Content-Type",
          "value": "multipart/form-data"
        },
        {
          "key": "Accept",
          "value": "application/json"
        }
      ],
      "pathVariables": [
        {
          "name": "meetingId",
          "type": "number",
          "required": true,
          "description": "Meeting ID"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company identifier"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch identifier"
        }
      ],
      "requestBody": {
        "type": "multipart/form-data",
        "fields": [
          {
            "name": "meeting",
            "type": "application/json",
            "required": true,
            "description": "Updated meeting properties"
          }
        ],
        "sample": {
          "meeting": {
            "startAtUtc": "2026-02-20T11:00:00",
            "endAtUtc": "2026-02-20T11:30:00",
            "agenda": "Updated agenda"
          }
        }
      },
      "response": null,
      "statusCodes": [
        {
            "code": 200,
            "description": "Ok"
          },
          {
            "code": 401,
            "description": "Invalid credentials"
          },
          {
            "code": 500,
            "description": "Internal server error"
          }
      ]
    },
