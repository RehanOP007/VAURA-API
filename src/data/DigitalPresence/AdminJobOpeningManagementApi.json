    {
      "id": "patch-job-status-only",
      "name": "Patch Job Status Only",
      "method": "PATCH",
      "endpoint": "/api/job-openings/{id}/status?{companyId}&{branchId}&{status=PUBLISHED}",
      "description": "Updates only the status of the job opening (fast status workflow).",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer YOUR_ADMIN_TOKEN"
        }
      ],
      "pathVariables": [
        {
          "name": "id",
          "type": "number",
          "required": true,
          "description": "Job opening ID"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company identifier"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch identifier"
        },
        {
          "name": "status",
          "type": "string",
          "required": true,
          "description": "New job status workflow value. Valid values: OPEN, WAITING_APPROVAL, DRAFT, PUBLISHED, DENIED, COMPLETED"
        }
      ],
      "requestBody": null,
      "response": null,
      "statusCodes": []
    },
