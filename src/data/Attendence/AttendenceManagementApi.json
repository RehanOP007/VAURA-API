{
  "module": 19,
  "category": "Attendance Management APIs",
  "apis": [
    {
      "id": "create-attendance-single-date",
      "name": "Create Attendance (Single Future Date)",
      "method": "POST",
      "endpoint": "/api/attendance/create-date?{companyId}&{branchId}",
      "description": "Creates attendance records for all employees for a single future date. Past or today’s dates are not allowed.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer YOUR_JWT_TOKEN"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company identifier"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch identifier"
        }
      ],
      "requestBody": {
        "type": "application/json",
        "sample": {
          "date": "2026-02-15"
        }
      },
      "response": null,
      "statusCodes": []
    },
    {
      "id": "create-attendance-full-month",
      "name": "Create Attendance (Full Month – Future Days Only)",
      "method": "POST",
      "endpoint": "/api/attendance/create-month?{companyId}&{branchId}",
      "description": "Creates attendance records for all future days only in the specified month. Existing or past attendance records are skipped automatically.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer YOUR_JWT_TOKEN"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company identifier"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch identifier"
        }
      ],
      "requestBody": {
        "type": "application/json",
        "sample": {
          "year": 2026,
          "month": 3
        }
      },
      "response": null,
      "statusCodes": []
    },
    {
      "id": "delete-future-attendance",
      "name": "Delete Future Attendance Records",
      "method": "DELETE",
      "endpoint": "/api/attendance/delete-future?{companyId}&{branchId}&{fromDate}",
      "description": "Deletes only future attendance records starting from the given date. Past and current day attendance cannot be deleted.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer YOUR_JWT_TOKEN"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company identifier"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch identifier"
        },
        {
          "name": "fromDate",
          "type": "string (YYYY-MM-DD)",
          "required": true,
          "description": "Delete attendance from this future date onward (e.g., 2026-03-01)"
        }
      ],
      "requestBody": null,
      "response": null,
      "statusCodes": []
    },
