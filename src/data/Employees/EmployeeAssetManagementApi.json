        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company ID"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch ID"
        },
        {
          "name": "assetId",
          "type": "number",
          "required": true,
          "description": "Asset ID"
        }
      ],
      "requestBody": null,
      "response": null,
      "statusCodes": [
        {
            "code": 200,
            "description": "Ok"
          },
          {
            "code": 401,
            "description": "Invalid credentials"
          },
          {
            "code": 500,
            "description": "Internal server error"
          }
      ]
    },
