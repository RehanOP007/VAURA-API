      "id": "upload-employee-document",
      "name": "Employee report documentation upload",
      "method": "POST",
      "endpoint": "/api/employee-documents?{companyId}&{branchId}",
      "description": "Uploads an employee report document configuration using form-data.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer ADMIN_TOKEN"
        },
        {
          "key": "Content-Type",
          "value": "multipart/form-data"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company identifier"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch identifier"
        }
      ],
      "requestBody": {
        "type": "multipart/form-data",
        "fields": [
          {
            "name": "file",
            "type": "file",
            "required": true,
            "description": "The report file document payload"
          },
          {
            "name": "data",
            "type": "application/json",
            "required": true,
            "description": "Metadata concerning the employee document"
          }
        ],
        "sample": {
          "data": {
            "employeeId": 12,
            "documentType": "POLICE_REPORT",
            "documentNumber": "PR-2026-001",
            "issueDate": "2026-03-19",
            "expiryDate": "2027-03-19",
            "remarks": "Uploaded from HR panel"
          }
        }
      },
      "response": null,
      "statusCodes": [
        {
            "code": 200,
            "description": "Ok"
          },
          {
            "code": 401,
            "description": "Invalid credentials"
          },
          {
            "code": 500,
            "description": "Internal server error"
          }
      ]
    },
