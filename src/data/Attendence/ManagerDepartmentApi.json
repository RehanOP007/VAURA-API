  "module": 22,
  "category": "Manager Department Attendance ",
  "apis": [
    {
      "id": "manager-department-attendance-date-only",
      "name": "Manager Department Attendance - Date Only",
      "method": "GET",
      "endpoint": "/api/attendance/department?{companyId}&{branchId}&{date}",
      "description": "Gets attendance records of employees in the logged-in manager’s department for a specific date.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer YOUR_JWT_TOKEN"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company ID"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch ID"
        },
        {
          "name": "date",
          "type": "string (YYYY-MM-DD)",
          "required": true,
          "description": "Attendance date"
        }
      ],
      "requestBody": null,
      "response": null,
      "statusCodes": []
    },
