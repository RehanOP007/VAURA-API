      "endpoint": "/api/employee-leave-policies/{id}?{companyId}&{branchId}",
      "description": "Removes an assigned leave policy from an employee.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer JWT_TOKEN"
        }
      ],
      "pathVariables": [
        {
          "name": "id",
          "type": "number",
          "required": true,
          "description": "Assigned leave policy record ID"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company ID"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch ID"
        }
      ],
      "requestBody": null,
      "response": null,
      "statusCodes": []
    },
