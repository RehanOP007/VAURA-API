      "id": "assign-designation-to-employee",
      "name": "Assign Designation to Employee",
      "method": "POST",
      "endpoint": "/api/employee-designation/assign?{companyId}&{branchId}&{employeeId}&{designationId}&{startDate}",
      "description": "Assigns a designation to an employee for the first time within the specified company and branch.",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer JWT_TOKEN"
        }
      ],
      "queryParams": [
        {
          "name": "companyId",
          "type": "number",
          "required": true,
          "description": "Company ID"
        },
        {
          "name": "branchId",
          "type": "number",
          "required": true,
          "description": "Branch ID"
        },
        {
          "name": "employeeId",
          "type": "number",
          "required": true,
          "description": "Employee ID"
        },
        {
          "name": "designationId",
          "type": "number",
          "required": true,
          "description": "Designation ID"
        },
        {
          "name": "startDate",
          "type": "string",
          "required": true,
          "description": "Start date of the designation (e.g. 2026-01-01)"
        }
      ],
      "requestBody": null,
      "response": null,
      "statusCodes": [
        {
            "code": 200,
            "description": "Ok"
          },
          {
            "code": 401,
            "description": "Invalid credentials"
          },
          {
            "code": 500,
            "description": "Internal server error"
          }
      ]
    },
