
 {
    "module": 10,
    "category": "Leave Policy APIs",
    "apis": [
      {
        "id": "add-leave-policy",
        "name": "Add Leave Policy",
        "method": "POST",
        "endpoint": "/api/leave-policies?{companyId}&{branchId}",
        "description": "Creates a new leave policy for a branch.",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer JWT_TOKEN"
          }
        ],
        "queryParams": [
          {
            "name": "companyId",
            "type": "number",
            "required": true,
            "description": "Company ID"
          },
          {
            "name": "branchId",
            "type": "number",
            "required": true,
            "description": "Branch ID"
          }
        ],
        "requestBody": {
          "type": "application/json",
          "sample": {
            "name": "Annual Leave",
            "leaveType": "FULL",
            "maxPerMonth": 2,
            "maxPerYear": 24,
            "medicalRequired": false,
            "allowHalfDay": true,
            "allowShortLeave": false,
            "carryForward": true
          }
        },
        "response": null,
        "statusCodes": []
      },
      {
        "id": "get-leave-policy-in-branch",
