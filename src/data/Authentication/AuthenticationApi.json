  {
    "module": 1,
    "category": "Authentication API",
    "apis": [
      {
        "id": "user-login",
        "name": "User Login",
        "method": "POST",
        "endpoint": "/api/auth/login",
        "description": "Authenticates a user and returns an access token",
        "headers": [{
            "key": "Content-Type",
            "value": "application/json"
          }],
        "queryParams": [{
            "name": "User Email",
            "type": "string",
            "required": true,
            "description": "useremail"
          },
          {
            "name": "User Password",
            "type": "string",
            "required": true,
            "description": "user password"
          }
        ],
        "requestBody": {
          "type": "application/json",
          "fields": [
            {
              "name": "email",
              "type": "String",
              "required": true,
              "description": "User email address"
            },
            {
              "name": "password",
              "type": "String",
              "required": true,
              "description": "User password"
            }
          ],
          "sample": {
                "username":"superadmin1",
                "password":"admin1234"
          }
        },
        "response": [
          {
             "token": "eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJzdXBlcmFkbWluMSIsInJvbGVzIjoiU1VQRVJBRE1JTiIsImlhdCI6MTc4MjM4Mzk2MCwiZXhwIjoxNzgyNDcwMzYwfQ.Z6xLb08x_kN9znqxvsWr0zUbMl7--mXvTLt8hIpfJWE",
             "adminId": 2,
             "employeeId": null,
             "companyId": null,
             "branchId": null,
             "departmentId": null,
             "username": "superadmin1",
             "roles": [
                 "SUPERADMIN"
                ],
            "status": "ACTIVE"
      }
        ],
        "statusCodes": [
          {
            "code": 200,
            "description": "Login successful"
          },
          {
            "code": 401,
            "description": "Invalid credentials"
          },
          {
            "code": 500,
            "description": "Internal server error"
          }
        
        ]
        
      },
      {
        "id": "change-own-password",
        "name": "Change Own Password",
        "method": "PUT",
        "endpoint": "/api/admins/me/password?{currentPassword}&{newPassword}",
        "description": "Allows currently logged-in admin to change own password. Validates current password before updating. Works for SUPERADMIN / BRANCHADMIN.",
        "headers": [
          {
            "key": "Authorization",
            "value": "Bearer JWT_TOKEN"
          }
        ],
        "queryParams": [
          {
            "name": "currentPassword",
            "type": "string",
            "required": true,
            "description": "Existing Password"
          },
          {
            "name": "newPassword",
            "type": "string",
            "required": true,
            "description": "New Password"
          }
        ],
        "requestBody": null,
        "response": null,
        "statusCodes": [
          {
            "code": 200,
            "description": "Ok"
          },
          {
            "code": 401,
            "description": "Invalid credentials"
          },
          {
            "code": 500,
            "description": "Internal server error"
          }
        ]
      }
    ]
  }